rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra para a coleção de produtos
    match /products/{productId} {
      // Qualquer um pode ler os produtos para ver o site
      allow read: if true;

      // APENAS você (seu e-mail) pode criar, editar ou deletar
      // Substitua pelo seu e-mail se desejar outro admin
      allow write: if request.auth != null && request.auth.token.email == 'lucasalves01@bol.com.br';
    }
  }
}
